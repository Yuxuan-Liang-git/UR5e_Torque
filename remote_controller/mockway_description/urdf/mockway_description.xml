<mujoco model="mockway_description">
  <compiler angle="radian" meshdir="../meshes" autolimits="true"/>
  <option integrator="implicitfast"/>

  <default>
    <default class="mockway">
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="collision">
        <geom type="mesh" group="3"/>
      </default>
      <joint axis="0 0 1"/>
    </default>
  </default>

  <asset>
    <mesh name="base_link_mesh" file="base_link.stl"/>
    <mesh name="link1_mesh" file="link1.stl"/>
    <mesh name="link2_mesh" file="link2.stl"/>
    <mesh name="link3_mesh" file="link3.stl"/>
    <mesh name="link4_mesh" file="link4.stl"/>
    <mesh name="link5_mesh" file="link5.stl"/>
    <mesh name="link6_mesh" file="link6.stl"/>

    <material name="base_blue" rgba="0.127 0.301 0.847 1.000"/>
    <material name="link1_purple" rgba="0.231 0.162 1.000 1.000"/>
    <material name="link2_teal" rgba="0.031 0.558 0.558 1.000"/>
    <material name="link3_orange" rgba="1.000 0.212 0.080 1.000"/>
    <material name="link4_magenta" rgba="0.701 0.162 0.672 1.000"/>
    <material name="link5_blue" rgba="0.061 0.223 0.456 1.000"/>
    <material name="link6_gray" rgba="0.527 0.527 0.527 1.000"/>
  </asset>

  <worldbody>
    <body name="base_link" childclass="mockway">
      <inertial pos="0 0 0.014" mass="0.097" fullinertia="0.000049 0.000049 0.000080 0 0 0"/>
      <geom class="visual" mesh="base_link_mesh" material="base_blue"/>
      <geom class="collision" mesh="base_link_mesh"/>

      <body name="link1" pos="0 0 0.064" euler="0 0 0">
        <joint name="joint1" axis="0 0 1" range="-6.280 6.280"/>
        <inertial pos="0 -0.003 -0.005" mass="0.378" fullinertia="0.000195 0.000176 0.000204 0 0 0.000005"/>
        <geom class="visual" mesh="link1_mesh" material="link1_purple"/>
        <geom class="collision" mesh="link1_mesh"/>

        <body name="link2" pos="0 0 0" euler="1.571 0 3.1415">
          <joint name="joint2" axis="0 0 1" range="-6.280 6.280"/>
          <inertial pos="0 0.035 0.069" mass="0.568" fullinertia="0.002661 0.000305 0.002654 0 0 -0.000043"/>
          <geom class="visual" mesh="link2_mesh" material="link2_teal"/>
          <geom class="collision" mesh="link2_mesh"/>

          <body name="link3" pos="0 0.190 0" euler="0 0 0">
            <joint name="joint3" axis="0 0 1" range="-3.140 3.140"/>
            <inertial pos="0 0.131 0.006" mass="0.488" fullinertia="0.001818 0.000257 0.001814 0 0 0.000079"/>
            <geom class="visual" mesh="link3_mesh" material="link3_orange"/>
            <geom class="collision" mesh="link3_mesh"/>

            <body name="link4" pos="0 0.163 0" euler="0 0 0">
              <joint name="joint4" axis="0 0 1" range="-6.280 6.280"/>
              <inertial pos="0 0.005 0.068" mass="0.378" fullinertia="0.000195 0.000204 0.000176 0 0 -0.000005"/>
              <geom class="visual" mesh="link4_mesh" material="link4_magenta"/>
              <geom class="collision" mesh="link4_mesh"/>

              <body name="link5" pos="0 0 0.071" euler="-1.571 0 1.517">
                <joint name="joint5" axis="0 0 1" range="-6.280 6.280"/>
                <inertial pos="0 -0.005 0.068" mass="0.378" fullinertia="0.000195 0.000204 0.000176 0 0 0.000005"/>
                <geom class="visual" mesh="link5_mesh" material="link5_blue"/>
                <geom class="collision" mesh="link5_mesh"/>

                <body name="link6" pos="0 -0.039 0.071" euler="1.571 0 0">
                  <joint name="joint6" axis="0 0 1" range="-6.280 6.280"/>
                  <inertial pos="0 0 -0.004" mass="0.016" fullinertia="0.000003 0.000003 0.000006 0 0 0"/>
                  <geom class="visual" mesh="link6_mesh" material="link6_gray"/>
                  <geom class="collision" mesh="link6_mesh"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="joint1_motor" joint="joint1" gear="1"/>
    <motor name="joint2_motor" joint="joint2" gear="1"/>
    <motor name="joint3_motor" joint="joint3" gear="1"/>
    <motor name="joint4_motor" joint="joint4" gear="1"/>
    <motor name="joint5_motor" joint="joint5" gear="1"/>
    <motor name="joint6_motor" joint="joint6" gear="1"/>
  </actuator>

  <keyframe>
    <key name="home" qpos="0 0 0 0 0 0"/>
  </keyframe>
</mujoco>
